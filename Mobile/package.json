{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "REACT_NATIVE_PACKAGER_HOSTNAME=localhost expo run:android",
    "android:build:apk": "cd android && ./gradlew assembleRelease",
    "android:build:aab": "cd android && ./gradlew bundleRelease",
    "android:distribute:apk": "cd android && ./gradlew assembleRelease appDistributionUploadRelease -PFIREBASE_ARTIFACT_TYPE=APK",
    "android:distribute:aab": "cd android && ./gradlew bundleRelease appDistributionUploadRelease -PFIREBASE_ARTIFACT_TYPE=AAB",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-firebase/remote-config": "^23.8.8",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.5",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-redux": "^9.2.0"
  },
  "private": true
}
